generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String
  orden     Int        @default(0)
  productos Producto[]
  creadoEn  DateTime   @default(now())

  @@map("categorias")
}

model Producto {
  id           String          @id @default(cuid())
  nombre       String
  descripcion  String
  precio       Int
  imagen       String
  activo       Boolean         @default(true)
  destacado    Boolean         @default(false)
  masVendido   Boolean         @default(false)
  etiquetas    String[]        @default([])
  categoriaId  String
  categoria    Categoria       @relation(fields: [categoriaId], references: [id])
  detalles     DetallePedido[]
  creadoEn     DateTime        @default(now())
  actualizadoEn DateTime       @updatedAt

  @@map("productos")
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String?
  pedidos   Pedido[]
  creadoEn  DateTime @default(now())

  @@map("clientes")
}

enum EstadoPedido {
  nuevo
  aceptado
  preparando
  listo
  entregado
  cancelado
}

model Pedido {
  id            String          @id @default(cuid())
  numero        Int             @default(autoincrement())
  mesa          String
  clienteId     String?
  cliente       Cliente?        @relation(fields: [clienteId], references: [id])
  nombreCliente String
  telefono      String?
  observaciones String?
  total         Int
  estado        EstadoPedido    @default(nuevo)
  items         DetallePedido[]
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt

  @@map("pedidos")
}

model DetallePedido {
  id           String   @id @default(cuid())
  pedidoId     String
  pedido       Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId   String
  producto     Producto @relation(fields: [productoId], references: [id])
  cantidad     Int
  precioUnidad Int

  @@map("detalle_pedidos")
}

model Usuario {
  id        String   @id @default(cuid())
  usuario   String   @unique
  claveHash String
  rol       String   @default("admin")
  creadoEn  DateTime @default(now())

  @@map("usuarios")
}

model Configuracion {
  id                String @id @default(cuid())
  nombreRestaurante String
  logoUrl           String?
  numeroWhatsapp    String
  correoNotificacion String?

  @@map("configuracion")
}
